# =========================================================
# Django environment
# =========================================================
DJANGO_ENV=dev

# =========================================================
# Core Django
# =========================================================
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=UTC

# =========================================================
# Database
# Step 9 keeps SQLite by default.
# Step 10 can switch this to PostgreSQL.
# =========================================================
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_SQLITE_NAME=db.sqlite3

# Example PostgreSQL values for later:
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=ai_powered_blog
# DJANGO_DB_USER=postgres
# DJANGO_DB_PASSWORD=postgres
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432

# =========================================================
# UI feature flags
# =========================================================
INTRO_OVERLAY_ENABLED=True
INTRO_OVERLAY_DURATION_MS=3600
INTRO_OVERLAY_IMAGE=images/intro/michal-portrait.png
SHOW_SIDEBAR_ON_HOME_STARTUP=True

# =========================================================
# Production-only examples
# =========================================================
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_SSL_REDIRECT=True
