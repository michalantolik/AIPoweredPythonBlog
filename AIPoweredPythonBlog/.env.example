# =========================================================
# Django environment
# =========================================================
DJANGO_ENV=dev

# =========================================================
# Core Django
# =========================================================
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=UTC

# =========================================================
# Database (PostgreSQL default target)
# =========================================================
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=ai_powered_blog
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=b191bda2d58b44728e0902583b82699e
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432

# =========================================================
# Optional local SQLite fallback
# Uncomment only if you want to run against SQLite again.
# =========================================================
# DJANGO_DB_ENGINE=django.db.backends.sqlite3
# DJANGO_SQLITE_NAME=db.sqlite3

# =========================================================
# UI feature flags
# =========================================================
INTRO_OVERLAY_ENABLED=True
INTRO_OVERLAY_DURATION_MS=3600
INTRO_OVERLAY_IMAGE=images/intro/michal-portrait.png
SHOW_SIDEBAR_ON_HOME_STARTUP=True
LIVE_POST_FILTER_ENABLED=False

# =========================================================
# Cookie / browser security
# =========================================================
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_HTTPONLY=True
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
DJANGO_APP_CSP_ENABLED=True
DJANGO_PERMISSIONS_POLICY_ENABLED=True

# =========================================================
# Production-only examples
# IMPORTANT:
# - never use ALLOWED_HOSTS=*
# - start HSTS with a small value like 3600, verify HTTPS,
#   then increase later
# =========================================================
# DJANGO_ENV=prod
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,.awsapprunner.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://*.awsapprunner.com
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=3600
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# DJANGO_SECURE_HSTS_PRELOAD=False
